<UserControl x:Class="MundoBrowser.QuickUrlOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="Transparent">
    
    <Grid>
        <!-- Semi-transparent background overlay -->
        <Border Background="#80000000" 
                MouseDown="Overlay_MouseDown"/>
        
        <!-- Main content card - centered -->
        <Border Width="600" Height="Auto"
                VerticalAlignment="Center"
                Background="#2D2D30"
                CornerRadius="12"
                Padding="20">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.6" BlurRadius="30" ShadowDepth="5" Direction="270"/>
            </Border.Effect>
            
            <Border.RenderTransform>
                <TranslateTransform/>
            </Border.RenderTransform>
            
            <StackPanel>
                <!-- Title removed for cleaner look -->
                
                <!-- URL Input Box -->
                <Border Background="#1E1E1E" 
                        CornerRadius="8"
                        BorderBrush="#3E3E42"
                        BorderThickness="2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Icon -->
                        <TextBlock Grid.Column="0" 
                                   Text="🔎" 
                                   FontSize="20"
                                   VerticalAlignment="Center"
                                   Foreground="#AAA"
                                   Margin="15,0,10,0"/>
                        
                        <!-- Text Input -->
                        <TextBox x:Name="UrlTextBox"
                                 Grid.Column="1"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="White"
                                 FontSize="18"
                                 VerticalAlignment="Center"
                                 Padding="5,14"
                                 CaretBrush="White"
                                 TextChanged="UrlTextBox_TextChanged"
                                 PreviewKeyDown="UrlTextBox_PreviewKeyDown">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Grid>
                                                    <ScrollViewer x:Name="PART_ContentHost"
                                                                  Focusable="False"
                                                                  HorizontalScrollBarVisibility="Hidden"
                                                                  VerticalScrollBarVisibility="Hidden"/>
                                                    <TextBlock Text="Où souhaitez-vous aller ?"
                                                               Foreground="#666"
                                                               FontSize="18"
                                                               IsHitTestVisible="False"
                                                               Padding="5,14"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Grid>
                </Border>
                
                <!-- Suggestions List -->
                <ListBox x:Name="SuggestionsList"
                         ItemsSource="{Binding Suggestions}"
                         Background="Transparent"
                         BorderThickness="0"
                         Margin="0,15,0,0"
                         MaxHeight="300"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         PreviewKeyDown="SuggestionsList_PreviewKeyDown"
                         PreviewMouseDown="SuggestionsList_PreviewMouseDown">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="ItemBorder" 
                                                Background="{TemplateBinding Background}" 
                                                Padding="{TemplateBinding Padding}"
                                                CornerRadius="6">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#3E3E42"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#4E4E52"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0" Text="🔗" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="#888"/>
                                
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Title}" FontWeight="Medium" FontSize="15" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Url}" FontSize="12" Foreground="#888" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                
                <!-- Hint text -->
                <TextBlock Text="Appuyez sur Entrée pour naviguer • Échap pour fermer"
                           FontSize="12"
                           Foreground="#888"
                           HorizontalAlignment="Center"
                           Margin="0,15,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
