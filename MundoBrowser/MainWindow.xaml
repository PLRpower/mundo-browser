<Window x:Class="MundoBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:vm="clr-namespace:MundoBrowser.ViewModels"
        mc:Ignorable="d"
        Title="MundoBrowser" Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        Foreground="White">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="1" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Key="D" Modifiers="Control" Command="{Binding ToggleSidebarCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        
        <!-- Standard Button Style with Gray Hover (for window controls - square) -->
        <Style x:Key="GrayHoverButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3D3D3D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#505050"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Navigation Button Style with Rounded Corners -->
        <Style x:Key="NavButtonStyle" TargetType="Button" BasedOn="{StaticResource GrayHoverButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3D3D3D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#505050"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>



        <!-- Scrollbar Style - Minimalist -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#444"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainGrid" MouseMove="Window_MouseMove">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" MinWidth="150" MaxWidth="400" /> <!-- Sidebar Column -->
            <ColumnDefinition Width="Auto" /> <!-- Splitter -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar Area -->
        <Grid Grid.Column="0" x:Name="SidebarGrid">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSidebarVisible}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            
            <Border Background="#252526" BorderThickness="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Title Bar / Drag Area -->
                        <RowDefinition Height="Auto"/> <!-- Add Tab Button -->
                        <RowDefinition Height="*"/>    <!-- Tabs List -->
                        <RowDefinition Height="Auto"/> <!-- Bottom Actions -->
                    </Grid.RowDefinitions>

                    <!-- App Title / Drag Area -->
                    <TextBlock Text="MUNDO" FontSize="16" FontWeight="Bold" Margin="20,15,0,15" Foreground="#A0A0A0" Grid.Row="0"/>

                    <!-- Add Tab Button (styled like a tab) -->
                    <Button Grid.Row="1" Command="{Binding AddNewTabCommand}" Margin="10,2" 
                            Background="Transparent" Foreground="#CCC" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="10,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="+" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Nouvel onglet" FontSize="14" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#2D2D30"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Tabs List -->
                    <ListBox Grid.Row="2" ItemsSource="{Binding Tabs}" SelectedItem="{Binding SelectedTab}" 
                             Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#CCC"/>
                                <Setter Property="Margin" Value="10,2"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Name="Border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#3E3E42"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                                <!-- Hover effect only when NOT selected -->
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsMouseOver" Value="True"/>
                                                        <Condition Property="IsSelected" Value="False"/>
                                                    </MultiTrigger.Conditions>
                                                    <Setter TargetName="Border" Property="Background" Value="#2D2D30"/>
                                                </MultiTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Tab Title -->
                                    <TextBlock Grid.Column="0" 
                                               Text="{Binding Title}" 
                                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                                               TextTrimming="CharacterEllipsis" 
                                               VerticalAlignment="Center" 
                                               FontSize="14"
                                               Margin="0,0,8,0"/>
                                    
                                    <!-- Close Tab Button (visible only on hover) -->
                                    <Button Grid.Column="1" 
                                            x:Name="CloseButton"
                                            Width="18" Height="18"
                                            Background="Transparent" 
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            ToolTip="Close Tab"
                                            Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="closeBorder" 
                                                        Background="{TemplateBinding Background}" 
                                                        CornerRadius="3">
                                                    <Path Data="M0,0 L6,6 M0,6 L6,0" 
                                                          Stroke="#888" 
                                                          StrokeThickness="1.5" 
                                                          Stretch="None" 
                                                          HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"
                                                          StrokeStartLineCap="Round" 
                                                          StrokeEndLineCap="Round"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="closeBorder" Property="Background" Value="#5A5A5A"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>  


                    
                    <!-- Load Extension Button -->
                    <Button Command="{Binding LoadExtensionCommand}" Margin="20,0,20,20" Height="40" 
                            Background="#2D4A2C" Foreground="White" BorderThickness="0" Grid.Row="3" VerticalAlignment="Bottom">
                        <Button.Template>
                             <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#3D6A3C"/> <!-- Lighter Green on Hover -->
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🧩" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Add Extension" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- GridSplitter for resizing sidebar -->
        <GridSplitter Grid.Column="1" Width="5" 
                      HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      Cursor="SizeWE"
                      Visibility="{Binding IsSidebarVisible, Converter={StaticResource BoolToVis}}"
                      DragDelta="GridSplitter_DragDelta"
                      Background="#252526"
                      BorderThickness="0"
                      ResizeBehavior="PreviousAndNext"
                      ResizeDirection="Columns">
        </GridSplitter>

        <!-- Main Content (Right) -->
        <Grid Grid.Column="2" Background="#1E1E1E">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Address Bar -->
                <RowDefinition Height="*"/>    <!-- WebView -->
            </Grid.RowDefinitions>

            <!-- Address Bar Area -->
            <Border Background="#252526" Height="40" Padding="15,0,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="3*"/>    <!-- URL Box takes 60% -->
                        <ColumnDefinition Width="*"/>     <!-- Empty space -->
                        <ColumnDefinition Width="Auto"/>  <!-- Extensions Icons -->
                        <ColumnDefinition Width="Auto"/>  <!-- Window Controls Column -->
                    </Grid.ColumnDefinitions>
                    
                    <!-- Nav Buttons -->
                    <StackPanel Orientation="Horizontal" Grid.Column="0" Margin="0,0,15,0" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Width="30" Height="30" Padding="8,8,0,0" Style="{StaticResource NavButtonStyle}" Click="Back_Click">
                            <!-- Left Arrow -->
                            <Path Data="M8,0 L0,5 L8,10" Stroke="White" StrokeThickness="1.5" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                        </Button>
                        <Button Width="30" Height="30" Style="{StaticResource NavButtonStyle}" Click="Forward_Click">
                            <!-- Right Arrow -->
                            <Path Data="M0,0 L8,5 L0,10" Stroke="White" StrokeThickness="1.5" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                        </Button>
                        <Button Width="30" Height="30" Style="{StaticResource NavButtonStyle}" Click="Reload_Click">
                            <!-- Reload Circle Arrow -->
                            <Path Data="M8,2 A4,4 0 1,1 2,5 M8,2 L8,0 M8,2 L10,2" Stroke="White" StrokeThickness="1.5" Fill="Transparent" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                        </Button>
                    </StackPanel>


                    <!-- URL Box -->
                    <Border Grid.Column="2" Background="#1E1E1E" CornerRadius="15" Height="30" VerticalAlignment="Center" 
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Select All Button -->
                            <Button Grid.Column="0" Width="24" Height="24" Margin="6,0,0,0"
                                    Background="Transparent" BorderThickness="0"
                                    Click="SelectAllUrl_Click"
                                    ToolTip="Select All"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                                            <Path Data="M2,2 L6,2 L6,6 L2,6 Z M4,4 L8,4 L8,8 L4,8 Z" 
                                                  Stroke="#888" StrokeThickness="1.2" 
                                                  Fill="Transparent"
                                                  Stretch="None" 
                                                  HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#2D2D30"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            
                            <!-- TextBox -->
                            <TextBox Grid.Column="1" x:Name="AddressTextBox"
                                     Text="{Binding SelectedTab.AddressUrl, UpdateSourceTrigger=PropertyChanged}" 
                                     Background="Transparent" BorderThickness="0" Foreground="White" 
                                     VerticalAlignment="Center" Margin="8,0,15,0" FontSize="14"
                                     CaretBrush="White"
                                     KeyDown="AddressBar_KeyDown"
                                     TextChanged="AddressTextBox_TextChanged"
                                     GotFocus="AddressTextBox_GotFocus"
                                     LostFocus="AddressTextBox_LostFocus">
                            </TextBox>
                            
                            <!-- Autocomplete Popup -->
                            <Popup x:Name="SuggestionsPopup" 
                                   PlacementTarget="{Binding ElementName=AddressTextBox}"
                                   Placement="Bottom"
                                   StaysOpen="False"
                                   AllowsTransparency="True"
                                   VerticalOffset="5"
                                   HorizontalOffset="-40">
                                <Border Background="#1E1E1E" 
                                        BorderBrush="#3E3E42" 
                                        BorderThickness="1" 
                                        CornerRadius="12" 
                                        Padding="4"
                                        Width="600">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" Opacity="0.5" BlurRadius="15" ShadowDepth="3" Direction="270"/>
                                    </Border.Effect>
                                    <ListBox x:Name="SuggestionsListBox"
                                             ItemsSource="{Binding Suggestions}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="White"
                                             MaxHeight="200"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             PreviewMouseDown="SuggestionsList_PreviewMouseDown">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="10,6"/>
                                                <Setter Property="Margin" Value="2"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="ItemBorder" 
                                                                    Background="{TemplateBinding Background}" 
                                                                    Padding="{TemplateBinding Padding}"
                                                                    CornerRadius="6"
                                                                    Margin="{TemplateBinding Margin}">
                                                                <ContentPresenter/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#2D2D30"/>
                                                                </Trigger>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#3E3E42"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <!-- Icon -->
                                                    <TextBlock Text="🔗" FontSize="14" 
                                                               VerticalAlignment="Center" 
                                                               Margin="0,0,8,0"/>
                                                    
                                                    <!-- Title -->
                                                    <TextBlock Text="{Binding Title}" 
                                                               FontWeight="Normal" 
                                                               FontSize="13" 
                                                               Foreground="White" 
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center"
                                                               MaxWidth="200"/>
                                                    
                                                    <!-- Separator -->
                                                    <TextBlock Text=" • " 
                                                               FontSize="13" 
                                                               Foreground="#555" 
                                                               VerticalAlignment="Center"
                                                               Margin="4,0"/>
                                                    
                                                    <!-- URL -->
                                                    <TextBlock Text="{Binding Url}" 
                                                               FontSize="12" 
                                                               Foreground="#888" 
                                                               TextTrimming="CharacterEllipsis" 
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                    <!-- Extensions Icons Bar -->
                    <ItemsControl Grid.Column="4" ItemsSource="{Binding InstalledExtensions}" 
                                  VerticalAlignment="Center" Margin="10,0"
                                  WindowChrome.IsHitTestVisibleInChrome="True">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Width="28" Height="28" Margin="2,0"
                                        Background="Transparent" BorderThickness="0"
                                        ToolTip="{Binding Name}"
                                        Cursor="Hand"
                                        Click="ExtensionIcon_Click"
                                        Tag="{Binding Id}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" 
                                                    CornerRadius="6" Padding="4">
                                                <!-- Puzzle piece icon as placeholder -->
                                                <TextBlock Text="🧩" FontSize="14" 
                                                           HorizontalAlignment="Center" 
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Background" Value="#3D3D3D"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Window Controls -->
                    <StackPanel Grid.Column="5" Orientation="Horizontal" Margin="0" VerticalAlignment="Stretch" HorizontalAlignment="Right" WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Click="Minimize_Click" Width="45" Height="40" Background="Transparent" BorderThickness="0" Style="{StaticResource GrayHoverButtonStyle}">
                             <Path Data="M0,2 L10,2" Stroke="White" StrokeThickness="1.5" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Button>
                        <Button Click="Maximize_Click" Width="45" Height="40" Background="Transparent" BorderThickness="0" Style="{StaticResource GrayHoverButtonStyle}">
                             <Path Data="M1,1 L9,1 L9,9 L1,9 Z" Stroke="White" StrokeThickness="1.5" Fill="Transparent" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center" StrokeLineJoin="Miter"/>
                        </Button>
                        <Button Click="Close_Click" Width="45" Height="40" Background="Transparent" BorderThickness="0" Style="{StaticResource GrayHoverButtonStyle}">
                            <Path Data="M0,0 L10,10 M0,10 L10,0" Stroke="White" StrokeThickness="1.5" Stretch="None" HorizontalAlignment="Right" Margin="0,0,6,0" VerticalAlignment="Center" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- WebView2 - Source is set programmatically after environment initialization -->
            <wv2:WebView2 Grid.Row="1" x:Name="BrowserView"/>
             
             <!-- Resize Edge Triggers - Allow resizing when WebView2 would otherwise block it -->
             <!-- Left edge for sidebar toggle -->
             <Border HorizontalAlignment="Left" Width="10" Background="Transparent" 
                     MouseEnter="Edge_MouseEnter" VerticalAlignment="Stretch" Grid.Row="0" Grid.RowSpan="2"/>
             
             <!-- Right edge for window resizing -->
             <Border HorizontalAlignment="Right" Width="5" Background="Transparent" 
                     VerticalAlignment="Stretch" Grid.Row="0" Grid.RowSpan="2" 
                     Cursor="SizeWE"/>
             
             <!-- Bottom edge for window resizing -->
             <Border VerticalAlignment="Bottom" Height="5" Background="Transparent" 
                     HorizontalAlignment="Stretch" Grid.Row="1" 
                     Cursor="SizeNS"/>
             
             <!-- Bottom-right corner for diagonal resizing -->
             <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" 
                     Width="10" Height="10" Background="Transparent" 
                     Grid.Row="1" Cursor="SizeNWSE"/>
        </Grid>
    </Grid>
</Window>
