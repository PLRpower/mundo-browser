<Window x:Class="MundoBrowser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:vm="clr-namespace:MundoBrowser.ViewModels"
        xmlns:local="clr-namespace:MundoBrowser"
        mc:Ignorable="d"
        Title="MundoBrowser" 
        Width="{Binding WindowWidth, Mode=TwoWay}" 
        Height="{Binding WindowHeight, Mode=TwoWay}"
        Left="{Binding WindowLeft, Mode=TwoWay}"
        Top="{Binding WindowTop, Mode=TwoWay}"
        WindowState="{Binding WindowState, Mode=TwoWay}"
        WindowStyle="None"
        PreviewKeyDown="Window_PreviewKeyDown"
        Background="#1E1E1E"
        Foreground="White">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.InputBindings>
    </Window.InputBindings>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        
        <!-- Style for manual resize edges - Hidden when maximized -->
        <Style x:Key="ResizeEdgeStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Standard Button Style with Gray Hover (for window controls - square) -->
        <Style x:Key="GrayHoverButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3D3D3D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#505050"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close Button Style with Red Hover -->
        <Style x:Key="RedHoverButtonStyle" TargetType="Button" BasedOn="{StaticResource GrayHoverButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C42B1C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D32F1F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Navigation Button Style with Rounded Corners -->
        <Style x:Key="NavButtonStyle" TargetType="Button" BasedOn="{StaticResource GrayHoverButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3D3D3D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#505050"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>



        <!-- Scrollbar Style - Minimalist -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track Name="PART_Track" IsDirectionReversed="true">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#444"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainGrid" MouseMove="Window_MouseMove" MouseDown="MainGrid_MouseDown" Focusable="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- TopBar : pleine largeur -->
            <RowDefinition Height="*"/>    <!-- Sidebar + WebView -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="250" MaxWidth="400" /> <!-- Sidebar Column -->
            <ColumnDefinition x:Name="SplitterColumn" Width="Auto" /> <!-- Splitter -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- TOP BAR — pleine largeur sur toute la fenêtre (Row 0) -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Border x:Name="TopBar" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                Background="#252526" Height="40">
            <Grid MouseDown="TitleBar_MouseDown" Background="Transparent">
                <Grid.ColumnDefinitions>
                    <!-- Col 0: Synced with sidebar but has a MinWidth to keep Nav buttons visible when sidebar is hidden -->
                    <ColumnDefinition Width="{Binding Width, ElementName=SidebarColumn}" MinWidth="140"/>
                    <ColumnDefinition Width="{Binding Width, ElementName=SplitterColumn}"/>
                    <ColumnDefinition Width="1.5*"/>    <!-- URL Box size reduced -->
                    <ColumnDefinition Width="*"/>       <!-- Empty space -->
                    <ColumnDefinition Width="Auto"/>  <!-- Extensions Icons -->
                    <ColumnDefinition Width="Auto"/>  <!-- Window Controls Column -->
                </Grid.ColumnDefinitions>
                
                <!-- Nav Buttons -->
                <StackPanel Orientation="Horizontal" Grid.Column="0" Margin="15,0,0,0" VerticalAlignment="Center" x:Name="NavButtonsStack">
                    <Button x:Name="BackButton" Width="30" Height="30" Style="{StaticResource NavButtonStyle}" Click="Back_Click">
                        <Viewbox Width="16" Height="16">
                            <Path Data="{StaticResource IconLeft}" Fill="White" Width="20" Height="20"/>
                        </Viewbox>
                    </Button>
                    <Button x:Name="ForwardButton" Width="30" Height="30" Style="{StaticResource NavButtonStyle}" Click="Forward_Click">
                        <Viewbox Width="16" Height="16">
                            <Path Data="{StaticResource IconRight}" Fill="White" Width="20" Height="20"/>
                        </Viewbox>
                    </Button>
                    <Button x:Name="ReloadButton" Width="30" Height="30" Style="{StaticResource NavButtonStyle}" Click="Reload_Click">
                        <Viewbox Width="16" Height="16">
                            <Path Data="{StaticResource IconRefresh}" Fill="White" Width="20" Height="20"/>
                        </Viewbox>
                    </Button>
                </StackPanel>

                <!-- URL Box -->
                <Border x:Name="UrlBarBorder" Grid.Column="2" Background="#1E1E1E" CornerRadius="15" Height="30" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="1.5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPendingNewTab}" Value="True">
                                    <Setter Property="BorderBrush" Value="#007ACC"/>
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect Color="#007ACC" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter Property="BorderBrush" Value="#007ACC"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <!-- TextBox + Placeholder -->
                        <Grid>
                            <TextBlock Text="Saisir l'adresse du nouvel onglet..."
                                       Foreground="#666" VerticalAlignment="Center" Margin="12,0,0,0"
                                       IsHitTestVisible="False" FontSize="13" FontStyle="Italic">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsPendingNewTab}" Value="True"/>
                                                    <Condition Binding="{Binding AddressBarText}" Value=""/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox x:Name="AddressTextBox"
                                     Text="{Binding AddressBarText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" BorderThickness="0" Foreground="White"
                                     VerticalAlignment="Center" Margin="12,0,15,0" FontSize="14"
                                     CaretBrush="White"
                                     KeyDown="AddressBar_KeyDown"
                                     TextChanged="AddressTextBox_TextChanged"
                                     GotFocus="AddressTextBox_GotFocus"
                                     LostFocus="AddressTextBox_LostFocus"
                                     PreviewMouseLeftButtonDown="AddressTextBox_PreviewMouseLeftButtonDown"/>
                        </Grid>

                        <!-- Autocomplete Popup -->
                        <Popup x:Name="SuggestionsPopup"
                               PlacementTarget="{Binding ElementName=AddressTextBox}"
                               Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
                               VerticalOffset="5" HorizontalOffset="-40">
                            <Border Background="#1E1E1E" BorderBrush="#3E3E42" BorderThickness="1"
                                    CornerRadius="12" Padding="4" Width="600">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" Opacity="0.5" BlurRadius="15" ShadowDepth="3" Direction="270"/>
                                </Border.Effect>
                                <ListBox x:Name="SuggestionsListBox"
                                         ItemsSource="{Binding Suggestions}"
                                         Background="Transparent" BorderThickness="0" Foreground="White"
                                         MaxHeight="200" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         PreviewMouseDown="SuggestionsList_PreviewMouseDown">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="10,6"/>
                                            <Setter Property="Margin" Value="2"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="ItemBorder"
                                                                Background="{TemplateBinding Background}"
                                                                Padding="{TemplateBinding Padding}"
                                                                CornerRadius="6" Margin="{TemplateBinding Margin}">
                                                            <ContentPresenter/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="ItemBorder" Property="Background" Value="#2D2D30"/>
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="ItemBorder" Property="Background" Value="#3E3E42"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🔗" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding Title}" FontWeight="Normal" FontSize="13" Foreground="White"
                                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" MaxWidth="200"/>
                                                <TextBlock Text=" • " FontSize="13" Foreground="#555" VerticalAlignment="Center" Margin="4,0"/>
                                                <TextBlock Text="{Binding Url}" FontSize="12" Foreground="#888"
                                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Popup>
                    </Grid>
                </Border>

                <!-- Extensions Icons Bar -->
                <ItemsControl x:Name="ExtensionsControl" Grid.Column="4" ItemsSource="{Binding InstalledExtensions}"
                               VerticalAlignment="Center" Margin="10,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button x:Name="ExtensionButton" Width="28" Height="28" Margin="2,0"
                                    Background="Transparent" BorderThickness="0"
                                    ToolTip="{Binding Name}" Cursor="Hand"
                                    Click="ExtensionIcon_Click" 
                                    Tag="{Binding Id}">
                                <Button.ContextMenu>
                                    <ContextMenu Background="#2D2D30" Foreground="White" BorderBrush="#3E3E42">
                                        <MenuItem Header="Supprimer l'extension" Click="RemoveExtension_Click" Tag="{Binding Id}">
                                            <MenuItem.Icon>
                                                <TextBlock Text="🗑️" VerticalAlignment="Center" FontSize="12"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </Button.ContextMenu>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="4">
                                            <Grid x:Name="IconGrid">
                                                <Image Source="{Binding IconSource}" Stretch="Uniform"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IconSource}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>
                                                <TextBlock Text="🧩" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IconSource}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#3D3D3D"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>


                <!-- Window Controls -->
                <StackPanel x:Name="WindowControlsStack" Grid.Column="5" Orientation="Horizontal"
                            Margin="0" VerticalAlignment="Stretch" HorizontalAlignment="Right">
                    <Button x:Name="MinimizeBtn" Click="Minimize_Click" Width="45" VerticalAlignment="Stretch"
                            Background="Transparent" BorderThickness="0" Style="{StaticResource GrayHoverButtonStyle}">
                        <Path Data="M0,2 L10,2" Stroke="White" StrokeThickness="1.5" Stretch="None"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Button>
                    <Button x:Name="MaximizeBtn" Click="Maximize_Click" Width="45" VerticalAlignment="Stretch"
                            Background="Transparent" BorderThickness="0" Style="{StaticResource GrayHoverButtonStyle}">
                        <Path Data="M1,1 L9,1 L9,9 L1,9 Z" Stroke="White" StrokeThickness="1.5"
                              Fill="Transparent" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center"
                              StrokeLineJoin="Miter"/>
                    </Button>
                    <Button x:Name="CloseBtn" Click="Close_Click" Width="45" VerticalAlignment="Stretch"
                            Background="Transparent" BorderThickness="0" Style="{StaticResource RedHoverButtonStyle}">
                        <Path Data="M0,0 L10,10 M0,10 L10,0" Stroke="White" StrokeThickness="1.5"
                              Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        <!-- Fin TopBar -->

        <!-- Normal Sidebar Area (Row 1) -->
        <local:SidebarView Grid.Row="1" Grid.Column="0" x:Name="SidebarGrid" Background="#252526">
            <local:SidebarView.Style>
                <Style TargetType="local:SidebarView">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSidebarVisible}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </local:SidebarView.Style>
        </local:SidebarView>

        <!-- Floating Sidebar Popup (to bypass WebView2 Airspace issue) -->
        <Popup x:Name="FloatingSidebarPopup" 
               AllowsTransparency="True" 
               PopupAnimation="None" 
               Placement="Relative"
               HorizontalOffset="0"
               VerticalOffset="40"
               StaysOpen="True"
               Width="250">
            <!-- La hauteur du popup couvre uniquement Row1 (sous la TopBar) -->
            <Grid Width="250" Height="{Binding ActualHeight, ElementName=ContentRow}" ClipToBounds="True" MouseLeave="FloatingSidebarContent_MouseLeave">
                <Border x:Name="FloatingSidebarContent" Background="#252526" CornerRadius="0" Margin="0">
                    <Border.RenderTransform>
                        <TranslateTransform X="0" />
                    </Border.RenderTransform>
                    <local:SidebarView />
                </Border>
            </Grid>
        </Popup>

        <!-- GridSplitter for resizing sidebar (Row 1) -->
        <GridSplitter Grid.Row="1" Grid.Column="1" Width="5" x:Name="SidebarSplitter"
                      HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      Cursor="SizeWE"
                      Visibility="{Binding IsSidebarVisible, Converter={StaticResource BoolToVis}}"
                      DragDelta="GridSplitter_DragDelta"
                      Background="#252526"
                      BorderThickness="0"
                      ResizeBehavior="PreviousAndNext"
                      ResizeDirection="Columns"/>

        <!-- ════════════════════════════════════════════════ -->
        <!-- CONTENU PRINCIPAL — WebView (Row 1, Col 2) -->
        <!-- ════════════════════════════════════════════════ -->
        <Grid x:Name="ContentRow" Grid.Row="1" Grid.Column="2" Background="#1E1E1E">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Extension Installation Bar -->
            <Border x:Name="ExtensionInstallBar" Grid.Row="0" Background="#2D2D30" BorderBrush="#3E3E42" BorderThickness="0,0,0,1"
                    Visibility="{Binding SelectedTab.IsExtensionStorePage, Converter={StaticResource BoolToVis}}">
                <Grid Margin="15,8">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🧩" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Cette extension est compatible avec MundoBrowser." Foreground="White" VerticalAlignment="Center" FontSize="13"/>
                        <Button x:Name="InstallExtensionBtn" Content="Installer l'extension" Click="InstallExtensionFromBar_Click" 
                                Margin="15,0" Padding="15,5" Cursor="Hand" Style="{StaticResource NavButtonStyle}" 
                                Background="#007ACC" FontWeight="SemiBold"/>
                        <ProgressBar x:Name="InstallProgressBar" Width="100" Height="4" VerticalAlignment="Center" Visibility="Collapsed" IsIndeterminate="True" Margin="10,0"/>
                        <TextBlock x:Name="InstallStatusText" Foreground="#888" VerticalAlignment="Center" FontSize="12" Visibility="Collapsed"/>
                    </StackPanel>
                    <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" 
                            Foreground="#888" Click="CloseInstallBar_Click" Width="30" FontSize="16" Cursor="Hand"
                            Style="{StaticResource GrayHoverButtonStyle}"/>
                </Grid>
            </Border>

            <!-- Container for multiple WebView2 instances (one per tab) -->
            <Grid x:Name="WebViewsContainer" Grid.Row="1"/>
        </Grid>
             
        <!-- Resize Edge Triggers - Moved to root for better hit testing over WebView2 -->
        <!-- Resize Edge Triggers -->
        <!-- Left edge for sidebar toggle (using Popup to catch mouse over WebView2) -->
        <Popup x:Name="EdgeTriggerPopup"
               AllowsTransparency="True"
               Placement="Relative"
               HorizontalOffset="0"
               VerticalOffset="0"
               Width="5"
               Height="{Binding ActualHeight, ElementName=MainGrid}">
            <Popup.Style>
                <Style TargetType="Popup">
                    <Setter Property="IsOpen" Value="False"/>
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsSidebarVisible}" Value="False"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="IsOpen" Value="True"/>
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </Popup.Style>
            <!-- #01000000 is almost completely transparent but still hit-testable -->
            <Border Background="#01000000" MouseEnter="Edge_MouseEnter" />
        </Popup>
             
        <!-- Right edge for window resizing -->
        <Border x:Name="RightResizeBorder" HorizontalAlignment="Right" Width="5" Style="{StaticResource ResizeEdgeStyle}" 
                VerticalAlignment="Stretch" Grid.ColumnSpan="3" 
                Panel.ZIndex="1000" Cursor="SizeWE"/>
             
        <!-- Bottom edge for window resizing -->
        <Border x:Name="BottomResizeBorder" VerticalAlignment="Bottom" Height="5" Style="{StaticResource ResizeEdgeStyle}" 
                HorizontalAlignment="Stretch" Grid.ColumnSpan="3" 
                Panel.ZIndex="1000" Cursor="SizeNS"/>
             
        <!-- Bottom-right corner for diagonal resizing -->
        <Border x:Name="BottomRightResizeBorder" HorizontalAlignment="Right" VerticalAlignment="Bottom" 
                Width="10" Height="10" Style="{StaticResource ResizeEdgeStyle}" 
                Grid.ColumnSpan="3" Panel.ZIndex="1001" Cursor="SizeNWSE"/>

        <!-- Popup for extensions - Moved to root for better event handling -->
        <Popup x:Name="ExtensionPopup"
               AllowsTransparency="False"
               StaysOpen="True"
               Placement="Bottom"
               Focusable="True"
               FocusManager.IsFocusScope="True"
               Opened="ExtensionPopup_Opened"
               Closed="ExtensionPopup_Closed"
               HorizontalOffset="0"
               VerticalOffset="5">
            <Border Background="#1E1E1E" BorderBrush="#3E3E42" BorderThickness="1" 
                    Width="400" Height="600" UseLayoutRounding="True" SnapsToDevicePixels="True">
                <Grid Background="#1E1E1E">
                    <wv2:WebView2 x:Name="ExtensionPopupWebView" 
                                  DefaultBackgroundColor="White"
                                  HorizontalAlignment="Stretch" 
                                  VerticalAlignment="Stretch"
                                  MinWidth="400" MinHeight="600"
                                  Loaded="ExtensionPopupWebView_Loaded"/>
                </Grid>
            </Border>
        </Popup>

    </Grid>
</Window>
