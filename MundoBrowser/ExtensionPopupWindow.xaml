<Window x:Class="MundoBrowser.ExtensionPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Extension" 
        Width="400" Height="600"
        WindowStartupLocation="Manual"
        Background="#1E1E1E"
        ResizeMode="CanResize"
        ShowInTaskbar="False">
    
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="5" GlassFrameThickness="0" CornerRadius="8"/>
    </WindowChrome.WindowChrome>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Title Bar -->
        <Border Grid.Row="0" Background="#252526">
            <Grid>
                <TextBlock x:Name="TitleText" Text="Extension" 
                           Foreground="#CCC" FontSize="12" 
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                <Button Content="✕" HorizontalAlignment="Right" 
                        Width="32" Height="32"
                        Background="Transparent" Foreground="White"
                        BorderThickness="0" Click="Close_Click"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#E81123"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
        
        <!-- Extension WebView -->
        <wv2:WebView2 Grid.Row="1" x:Name="ExtensionWebView"/>
    </Grid>
</Window>
