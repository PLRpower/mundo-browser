<UserControl x:Class="MundoBrowser.SidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MundoBrowser"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="250">
    <Border Background="Transparent" BorderThickness="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title Bar / Drag Area -->
                <RowDefinition Height="Auto"/> <!-- Add Tab Button -->
                <RowDefinition Height="*"/>    <!-- Tabs List -->
                <RowDefinition Height="Auto"/> <!-- Bottom Actions -->
            </Grid.RowDefinitions>

            <!-- App Title / Drag Area -->
            <TextBlock Text="MUNDO" FontSize="16" FontWeight="Bold" Margin="20,15,0,15" Foreground="#A0A0A0" Grid.Row="0"/>

            <!-- Top Section: Add Tab + Cleaner Separator (Row 1) -->
            <StackPanel Grid.Row="1" Margin="0,0,0,5">
                <Button Command="{Binding AddNewTabCommand}" Margin="10,2" 
                        Background="Transparent" Foreground="#CCC" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="10,8">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="15" Height="15" Margin="0,0,8,0">
                                        <Path Data="{StaticResource IconPlus}" Fill="#CCC" Width="20" Height="20"/>
                                    </Viewbox>
                                    <TextBlock Text="Nouvel onglet" FontSize="14" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#2D2D30"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Separator with Clean button -->
                <Grid Margin="20,10,15,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Rectangle Height="1" Fill="#333333" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Button Grid.Column="1" Command="{Binding CloseOtherTabsCommand}" 
                            Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <TextBlock x:Name="text" Text="Nettoyer" FontSize="11" Foreground="#666666" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="text" Property="Foreground" Value="#AAAAAA"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </StackPanel>

            <!-- Tabs List -->
            <ListBox x:Name="TabsListBox" Grid.Row="2" ItemsSource="{Binding Tabs}" SelectedItem="{Binding SelectedTab}" 
                     Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     AllowDrop="True" Drop="TabsList_Drop" DragOver="TabsList_DragOver" DragLeave="TabsList_DragLeave"
                     Padding="0,2" ClipToBounds="False">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#CCC"/>
                        <Setter Property="Margin" Value="10,0"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <EventSetter Event="PreviewMouseLeftButtonDown" Handler="TabItem_PreviewMouseLeftButtonDown"/>
                        <EventSetter Event="PreviewMouseMove" Handler="TabItem_PreviewMouseMove"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Grid Background="Transparent">
                                        <Border x:Name="TopIndicator" Height="2" Background="White" VerticalAlignment="Top" Margin="0,-1,0,0" Visibility="Collapsed" Panel.ZIndex="10"/>
                                        <Border x:Name="BottomIndicator" Height="2" Background="White" VerticalAlignment="Bottom" Margin="0,0,0,-1" Visibility="Collapsed" Panel.ZIndex="10"/>
                                        <Border Name="Border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}" Margin="0,2">
                                            <ContentPresenter />
                                        </Border>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#3E3E42"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsMouseOver" Value="True"/>
                                                <Condition Property="IsSelected" Value="False"/>
                                            </MultiTrigger.Conditions>
                                            <Setter TargetName="Border" Property="Background" Value="#2D2D30"/>
                                        </MultiTrigger>
                                        <Trigger Property="Tag" Value="DropTop">
                                            <Setter TargetName="TopIndicator" Property="Visibility" Value="Visible"/>
                                        </Trigger>
                                        <Trigger Property="Tag" Value="DropBottom">
                                            <Setter TargetName="BottomIndicator" Property="Visibility" Value="Visible"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Grid Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Center">
                                    <!-- Fallback Icon if no favicon -->
                                    <TextBlock Text="🌐" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FaviconUrl}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding FaviconUrl}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <!-- Actual Favicon -->
                                    <Image Source="{Binding FaviconUrl}" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FaviconUrl}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding FaviconUrl}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Grid>
                                
                                <TextBlock Text="{Binding Title}" 
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" FontSize="14" Margin="0,0,8,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" x:Name="CloseButton" Width="18" Height="18" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Close Tab"
                                    Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Opacity" Value="0"/>
                                        <Setter Property="IsHitTestVisible" Value="False"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                <Setter Property="Opacity" Value="1"/>
                                                <Setter Property="IsHitTestVisible" Value="True"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="closeBorder" Background="{TemplateBinding Background}" CornerRadius="3">
                                            <Path Data="M0,0 L6,6 M0,6 L6,0" Stroke="#888" StrokeThickness="1.5" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="closeBorder" Property="Background" Value="#5A5A5A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Load Extension Button -->
            <Button Command="{Binding LoadExtensionCommand}" Margin="20,0,20,20" Height="40" 
                    Background="#2D4A2C" Foreground="White" BorderThickness="0" Grid.Row="3" VerticalAlignment="Bottom">
                <Button.Template>
                     <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3D6A3C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🧩" FontSize="16" Margin="0,0,8,0"/>
                    <TextBlock Text="Add Extension" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </StackPanel>
            </Button>
        </Grid>
    </Border>
</UserControl>