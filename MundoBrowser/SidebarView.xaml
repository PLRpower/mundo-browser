<UserControl x:Class="MundoBrowser.SidebarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MundoBrowser"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="250">
    <UserControl.Resources>
        <local:BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="MediaButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.7"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Background="Transparent" BorderThickness="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Pinned Tabs Section -->
                <RowDefinition Height="0"/>    <!-- Title Bar removed -->
                <RowDefinition Height="Auto"/> <!-- Add Tab Button -->
                <RowDefinition Height="*"/>    <!-- Tabs List -->
                <RowDefinition Height="Auto"/> <!-- Bottom Actions -->
                <RowDefinition Height="Auto"/> <!-- Media Control Bar -->
            </Grid.RowDefinitions>

            <!-- Pinned Tabs Section (Row 0) -->
            <ItemsControl Grid.Row="0" Margin="5,10,5,5" ItemsSource="{Binding PinnedTabs}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="3" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Background="#2D2D30" Margin="2" Padding="0" BorderThickness="2" BorderBrush="Transparent"
                                Command="{Binding DataContext.OpenPinnedTabCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                Height="50" Cursor="Hand" ToolTip="{Binding Tab.Title}"
                                AllowDrop="True" Drop="PinnedSlot_Drop" DragOver="PinnedSlot_DragOver"
                                DragEnter="PinnedSlot_DragEnter" DragLeave="PinnedSlot_DragLeave">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                            <Setter Property="BorderBrush" Value="#333"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="12" 
                                            BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}"
                                            RenderTransformOrigin="0.5,0.5">
                                        <Border.RenderTransform>
                                            <ScaleTransform x:Name="btnScale" ScaleX="1" ScaleY="1" />
                                        </Border.RenderTransform>
                                        <Grid>
                                            <!-- Placeholder Icon -->
                                            <TextBlock x:Name="EmptyIcon" Text="+" FontSize="10" Foreground="#444" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            
                                            <!-- Pinned Content -->
                                            <Grid x:Name="PinnedContent" Visibility="Collapsed">
                                                <!-- Image Favicon -->
                                                <Image Source="{Binding Tab.FaviconUrl}" Width="18" Height="18" Stretch="Uniform" 
                                                       SnapsToDevicePixels="True" UseLayoutRounding="True"
                                                       RenderOptions.BitmapScalingMode="HighQuality">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Tab.FaviconUrl}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Tab.FaviconUrl}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>
                                                <!-- Fallback Emoji -->
                                                <TextBlock Text="🌐" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Tab.FaviconUrl}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Tab.FaviconUrl}" Value="">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsEmpty}" Value="False">
                                            <Setter TargetName="PinnedContent" Property="Visibility" Value="Visible"/>
                                            <Setter TargetName="EmptyIcon" Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter TargetName="border" Property="BorderBrush" Value="#E91E63"/>
                                            <Setter TargetName="border" Property="Background" Value="#3D2D30"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#3E3E42"/>
                                            <Setter TargetName="border" Property="BorderBrush" Value="#555"/>
                                        </Trigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True"/>
                                                <Condition Binding="{Binding IsSelected}" Value="True"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter TargetName="border" Property="BorderBrush" Value="#FF4081"/>
                                        </MultiDataTrigger>
                                        <DataTrigger Binding="{Binding IsDraggingOver}" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#444"/>
                                            <Setter TargetName="border" Property="BorderBrush" Value="#007ACC"/>
                                            <Setter TargetName="border" Property="RenderTransform">
                                                <Setter.Value>
                                                    <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#1E1E1E"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- App Title / Drag Area removed -->


            <!-- Top Section: Add Tab + Cleaner Separator (Row 2) -->
            <StackPanel Grid.Row="2" Margin="0,0,0,5">
                <Button Command="{Binding AddNewTabCommand}" Margin="10,2" 
                        Background="Transparent" Foreground="#CCC" BorderThickness="0" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="10,8">
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="15" Height="15" Margin="0,0,8,0">
                                        <Path Data="{StaticResource IconPlus}" Fill="#CCC" Width="20" Height="20"/>
                                    </Viewbox>
                                    <TextBlock Text="Nouvel onglet" FontSize="14" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#2D2D30"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Separator with Clean button -->
                <Grid Margin="20,10,15,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Rectangle Height="1" Fill="#333333" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Button Grid.Column="1" Command="{Binding CloseOtherTabsCommand}" 
                            Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <TextBlock x:Name="text" Text="Nettoyer" FontSize="11" Foreground="#666666" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="text" Property="Foreground" Value="#AAAAAA"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </StackPanel>

            <!-- Tabs List -->
            <ListBox x:Name="TabsListBox" Grid.Row="3" ItemsSource="{Binding Tabs}" SelectedItem="{Binding SelectedListTab}" 
                     Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     AllowDrop="True" Drop="TabsList_Drop" DragOver="TabsList_DragOver" DragLeave="TabsList_DragLeave"
                     Padding="0,2" ClipToBounds="False">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#CCC"/>
                        <Setter Property="Margin" Value="5,0"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <EventSetter Event="PreviewMouseLeftButtonDown" Handler="TabItem_PreviewMouseLeftButtonDown"/>
                        <EventSetter Event="PreviewMouseMove" Handler="TabItem_PreviewMouseMove"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Grid Background="Transparent">
                                        <Border x:Name="TopIndicator" Height="2" Background="White" VerticalAlignment="Top" Margin="0,-1,0,0" Visibility="Collapsed" Panel.ZIndex="10"/>
                                        <Border x:Name="BottomIndicator" Height="2" Background="White" VerticalAlignment="Bottom" Margin="0,0,0,-1" Visibility="Collapsed" Panel.ZIndex="10"/>
                                        <Border Name="Border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}" Margin="0,2">
                                            <ContentPresenter />
                                        </Border>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#3E3E42"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsMouseOver" Value="True"/>
                                                <Condition Property="IsSelected" Value="False"/>
                                            </MultiTrigger.Conditions>
                                            <Setter TargetName="Border" Property="Background" Value="#2D2D30"/>
                                        </MultiTrigger>
                                        <Trigger Property="Tag" Value="DropTop">
                                            <Setter TargetName="TopIndicator" Property="Visibility" Value="Visible"/>
                                        </Trigger>
                                        <Trigger Property="Tag" Value="DropBottom">
                                            <Setter TargetName="BottomIndicator" Property="Visibility" Value="Visible"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Center">
                                    <!-- Fallback Icon if no favicon -->
                                    <TextBlock Text="🌐" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FaviconUrl}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding FaviconUrl}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <!-- Actual Favicon -->
                                    <Image Source="{Binding FaviconUrl}" Width="16" Height="16" Stretch="Uniform" 
                                           SnapsToDevicePixels="True" UseLayoutRounding="True"
                                           RenderOptions.BitmapScalingMode="HighQuality">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FaviconUrl}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding FaviconUrl}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                </Grid>
                                
                                <TextBlock Grid.Column="1" Text="{Binding Title}" 
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" FontSize="14" Margin="0,0,2,0"/>
                            </Grid>
                            <Button Grid.Column="1" x:Name="CloseButton" Width="18" Height="18" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Close Tab"
                                    Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="closeBorder" Background="{TemplateBinding Background}" CornerRadius="3">
                                            <Path Data="M0,0 L6,6 M0,6 L6,0" Stroke="#888" StrokeThickness="1.5" Stretch="None" HorizontalAlignment="Center" VerticalAlignment="Center" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="closeBorder" Property="Background" Value="#5A5A5A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Media Control Bar (Row 5) -->
            <Border Grid.Row="5" x:Name="MediaBar" Background="#0A0A0A" CornerRadius="12" Margin="10,5,10,15" Padding="12,10">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding ActiveMediaTab, Converter={x:Static local:Converters.NullToBool}}" Value="True"/>
                                    <Condition Binding="{Binding IsMediaBarVisible}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                
                <Grid DataContext="{Binding ActiveMediaTab}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Expanded Info (Artist/Title/Progress) -->
                        <RowDefinition Height="Auto"/> <!-- Main Controls -->
                    </Grid.RowDefinitions>

                    <!-- Expanded Info (Visible on hover) -->
                    <Grid Grid.Row="0" x:Name="ExpandedInfo" Visibility="Collapsed" Margin="0,0,0,15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Close Button (Top Right) -->
                        <Button Grid.Row="0" HorizontalAlignment="Right" Style="{StaticResource MediaButtonStyle}" 
                                Command="{Binding DataContext.CloseMediaBarCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Margin="0,-5,-5,0">
                            <Path Data="M0,0 L8,8 M0,8 L8,0" Stroke="#666" StrokeThickness="1.5" Stretch="Uniform" Width="8" Height="8"/>
                        </Button>

                        <!-- Title and Artist -->
                        <StackPanel Grid.Row="1" Margin="0,0,20,0">
                            <TextBlock Text="{Binding MediaTitle}" Foreground="White" FontWeight="Bold" FontSize="13" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding MediaArtist}" Foreground="#888" FontSize="11" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <!-- Progress Bar -->
                        <Grid Grid.Row="2" Margin="0,15,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <TextBlock Text="{Binding MediaPositionText}" Foreground="#CC8888" FontSize="10" HorizontalAlignment="Left"/>
                                <TextBlock Text="{Binding MediaDurationText}" Foreground="#888" FontSize="10" HorizontalAlignment="Right"/>
                            </Grid>
                            <Slider Grid.Row="1" Value="{Binding MediaProgressRatio}" Height="20" Margin="0,-5,0,0"
                                    Minimum="0" Maximum="100" VerticalAlignment="Center"
                                    Thumb.DragStarted="OnMediaSliderDragStarted"
                                    Thumb.DragCompleted="OnMediaSliderDragCompleted">
                                <Slider.Resources>
                                    <Style TargetType="{x:Type RepeatButton}">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                </Slider.Resources>
                                <Slider.Style>
                                    <Style TargetType="Slider">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Slider">
                                                    <Grid>
                                                        <Border Background="#333" Height="3" CornerRadius="1.5" VerticalAlignment="Center"/>
                                                        <Track x:Name="PART_Track">
                                                            <Track.DecreaseRepeatButton>
                                                                <RepeatButton>
                                                                    <Border Background="#883333" Height="3" CornerRadius="1.5"/>
                                                                </RepeatButton>
                                                            </Track.DecreaseRepeatButton>
                                                            <Track.Thumb>
                                                                <Thumb Width="8" Height="8">
                                                                    <Thumb.Template>
                                                                        <ControlTemplate TargetType="Thumb">
                                                                            <Ellipse Fill="White" Width="8" Height="8"/>
                                                                        </ControlTemplate>
                                                                    </Thumb.Template>
                                                                </Thumb>
                                                            </Track.Thumb>
                                                        </Track>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Slider.Style>
                            </Slider>
                        </Grid>
                    </Grid>

                    <!-- Main Controls (Row 1) -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Music Icon (Left) -->
                        <Grid Grid.Column="0" VerticalAlignment="Center">
                            <Border Width="24" Height="24" CornerRadius="12" ClipToBounds="True" Background="#1A1A1A">
                                <Path Data="{StaticResource IconMediaMusic}" Fill="#FF4444" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <!-- Controls (Center) -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Style="{StaticResource MediaButtonStyle}" Command="{Binding DataContext.MediaPreviousCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                <Path Data="{StaticResource IconMediaPrev}" Fill="#CCC" Width="14" Height="14" Stretch="Uniform"/>
                            </Button>
                            
                            <!-- Play/Pause (Center) -->
                            <Button Style="{StaticResource MediaButtonStyle}" Margin="15,0"
                                    Command="{Binding DataContext.MediaPlayPauseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                <Path Fill="White" Width="14" Height="14" Stretch="Uniform">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Data" Value="{StaticResource IconMediaPause}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMediaPaused}" Value="True">
                                                    <Setter Property="Data" Value="{StaticResource IconMediaPlay}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                            </Button>

                            <Button Style="{StaticResource MediaButtonStyle}" Command="{Binding DataContext.MediaNextCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                <Path Data="{StaticResource IconMediaNext}" Fill="#CCC" Width="14" Height="14" Stretch="Uniform"/>
                            </Button>
                        </StackPanel>

                        <!-- Volume (Right) -->
                        <Button Grid.Column="2" Style="{StaticResource MediaButtonStyle}" 
                                Command="{Binding DataContext.MediaVolumeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                            <Path x:Name="VolIcon" Fill="#AAA" Width="12" Height="12" Stretch="Uniform">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Data" Value="{StaticResource IconMediaVolume}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMediaMuted}" Value="True">
                                                <Setter Property="Data" Value="{StaticResource IconMediaMuted}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                        </Button>
                    </Grid>
                </Grid>

                <Border.Triggers>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ExpandedInfo" Storyboard.TargetProperty="Visibility">
                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                </ObjectAnimationUsingKeyFrames>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ExpandedInfo" Storyboard.TargetProperty="Visibility">
                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                                </ObjectAnimationUsingKeyFrames>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
            </Border>
        </Grid>
    </Border>
</UserControl>