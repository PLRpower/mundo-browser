<Window x:Class="MundoBrowser.AddExtensionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Extension" 
        Height="400" 
        Width="600"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <!-- Modern button style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1084D8"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#555555"/>
                    <Setter Property="Foreground" Value="#999999"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Close button style -->
        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBox style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>
    </Window.Resources>

    <Border Background="#1E1E1E" 
            CornerRadius="8"
            BorderBrush="#3A3A3A" 
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="70"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" 
                    Background="#252525"
                    CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Add Extension from Chrome Web Store"
                               Foreground="White"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="20,0,0,0"/>

                    <Button Grid.Column="1"
                            Click="Close_Click"
                            Style="{StaticResource CloseButton}"
                            Width="40"
                            Height="40"
                            Margin="0,0,10,0"
                            Content="✕"
                            FontSize="16"/>
                </Grid>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" 
                        Margin="30,20,30,10">
                
                <!-- Instructions -->
                <TextBlock Foreground="#CCCCCC" 
                           FontSize="13"
                           TextWrapping="Wrap"
                           Margin="0,0,0,15">
                    Enter the Chrome Web Store URL or extension ID to install:
                </TextBlock>

                <!-- URL/ID input -->
                <TextBox x:Name="ExtensionUrlTextBox"
                         Height="40"
                         VerticalContentAlignment="Center"
                         TextChanged="ExtensionUrlTextBox_TextChanged"/>

                <!-- Examples -->
                <TextBlock Foreground="#888888" 
                           FontSize="11"
                           TextWrapping="Wrap"
                           Margin="0,10,0,0">
                    <Run Text="Example URL: "/>
                    <Hyperlink Foreground="#0078D4" 
                               TextDecorations="None"
                               Click="ExampleUrl_Click">
                        https://chrome.google.com/webstore/detail/bitwarden/nngceckbapebfimnlniiiahkandclblb
                    </Hyperlink>
                </TextBlock>

                <TextBlock Foreground="#888888" 
                           FontSize="11"
                           Margin="0,5,0,0">
                    <Run Text="Example ID: "/>
                    <Run Text="nngceckbapebfimnlniiiahkandclblb" FontFamily="Consolas"/>
                </TextBlock>

                <!-- Status message -->
                <Border x:Name="StatusBorder" 
                        Margin="0,20,0,0"
                        Padding="15,10"
                        CornerRadius="4"
                        Background="#2D2D2D"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock x:Name="StatusText"
                                   Foreground="White"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                        
                        <!-- Progress indicator -->
                        <ProgressBar x:Name="ProgressBar"
                                     Height="3"
                                     Margin="0,10,0,0"
                                     IsIndeterminate="True"
                                     Visibility="Collapsed"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Buttons -->
            <Border Grid.Row="2" 
                    Background="#252525"
                    CornerRadius="0,0,8,8"
                    BorderBrush="#3A3A3A"
                    BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right"
                            Margin="30,15">
                    <Button Content="Cancel"
                            Style="{StaticResource CloseButton}"
                            Width="100"
                            Click="Cancel_Click"
                            Margin="0,0,10,0"/>
                    
                    <Button x:Name="InstallButton"
                            Content="Install"
                            Style="{StaticResource ModernButton}"
                            Width="100"
                            Click="Install_Click"
                            IsEnabled="False"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
